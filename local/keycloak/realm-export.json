{
  "realm": "ndc",
  "enabled": true,
  "displayName": "NDC Admin (local)",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 28800,
  "roles": {
    "realm": [
      { "name": "ndc-admin", "description": "Pannello admin - tutte le manovre" },
      { "name": "ndc-viewer", "description": "Pannello admin - sola lettura" },
      { "name": "ndc-service", "description": "Identita di servizio (cron / scheduler)" }
    ]
  },
  "clientScopes": [
    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "OpenID Connect built-in scope: email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "roles",
      "description": "OpenID Connect scope: include i realm roles dell'utente nel claim realm_access.roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "ndc-admin-bff-client",
      "name": "NDC Admin BFF",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "local-development-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/login/oauth2/code/keycloak",
        "http://localhost:5173/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:5173"
      ],
      "attributes": {},
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "ndc-cron-service-client",
      "name": "NDC Cron Service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "local-cron-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "attributes": {},
      "defaultClientScopes": ["roles"],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "mario.rossi",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Mario",
      "lastName": "Rossi",
      "email": "mario.rossi@example.com",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["ndc-admin"]
    },
    {
      "username": "giulia.viewer",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Giulia",
      "lastName": "Viewer",
      "email": "giulia.viewer@example.com",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["ndc-viewer"]
    },
    {
      "username": "service-account-ndc-cron-service-client",
      "enabled": true,
      "serviceAccountClientId": "ndc-cron-service-client",
      "realmRoles": ["ndc-service"]
    }
  ]
}
